# shellcheck disable=all

backtick TZ { /command/with-contenv /bin/bash -c "echo ${TZ:-"America/New_York"}" }
importas tz TZ

if { test -f "/usr/share/zoneinfo/${tz}" }
foreground { /bin/ln -snf "/usr/share/zoneinfo/${tz}" /etc/localtime }
foreground { redirfd -w 1 /etc/timezone echo "${tz}" }
